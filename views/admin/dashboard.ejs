<!DOCTYPE html>
<html>
<head>
    <title>Admin Dashboard</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

    <style>

        body{
            margin:0;
            background:#f5f5f5;
        }

        .sidebar{
            width:250px;
            height:100vh;
            background:#8e24aa;
            position:fixed;
            padding:20px;
        }

        .sidebar h3{
            color:white;
            text-align:center;
            margin-bottom:30px;
        }

        .sidebar a{
            display:block;
            text-decoration:none;
            color:white;
            padding:12px;
            border-radius:8px;
            margin-bottom:10px;
        }

        .sidebar a:hover{
            background:white;
            color:#8e24aa;
        }

        .content{
            margin-left:270px;
            padding:30px;
        }

    </style>

</head>

<body>

<div class="sidebar">

    <h3>Meesho Admin</h3>

    <a href="/admin">🏠 Dashboard</a>

    <a href="/admin/add_product">📦 Add Product</a>

    <a href="#">🛒 Orders</a>

    <a href="#">👤 Users</a>

</div>

<div class="content">

    <h2 class="mb-4">Dashboard</h2>

    <div class="row">

        <div class="col-md-4">
            <div class="card shadow border-0 p-4">
                <h5>Total Products</h5>
                <h2>0</h2>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card shadow border-0 p-4">
                <h5>Total Users</h5>
                <h2>0</h2>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card shadow border-0 p-4">
                <h5>Total Orders</h5>
                <h2>0</h2>
            </div>
        </div>

    </div>

</div>
</body>
</html>