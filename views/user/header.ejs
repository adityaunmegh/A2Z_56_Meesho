  <!-- ================= TOP NAVBAR ================= -->
  <header class="navbar">
    <div class="logo">
      <h1>meesho</h1>
    </div>

    <div class="search-box">
      <i class="fa-solid fa-magnifying-glass"></i>
      <input type="text" placeholder="Try Saree, Kurti or Search by Product Code" />
